# ============================================================
# AETHER Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Database
DATABASE_URL="postgresql://aether:aether@localhost:5432/aether"
TIMESCALE_URL="postgresql://aether:aether@localhost:5433/aether_weather"
REDIS_URL="redis://localhost:6379"

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Payments (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_YEARLY_PRICE_ID="price_..."

# External Weather APIs
NWS_API_USER_AGENT="Aether/1.0 (contact@aether.weather)"
OPENWEATHER_API_KEY=""
ECMWF_API_KEY=""
WUNDERGROUND_API_KEY=""
AIRNOW_API_KEY=""
VAISALA_API_KEY=""

# Geocoding
MAPBOX_TOKEN=""

# Infrastructure
KAFKA_BROKER="localhost:9092"
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="masterKey"

# Monitoring
SENTRY_DSN=""
GRAFANA_API_KEY=""

# Push Notifications
FCM_SERVICE_ACCOUNT_JSON=""
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_KEY_FILE=""

# SMS Fallback
TELNYX_API_KEY=""
TELNYX_FROM_NUMBER=""

# CDN / Edge
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="aether-assets"

# Feature Flags
LAUNCHDARKLY_SDK_KEY=""

# Analytics
MIXPANEL_TOKEN=""

# LLM (Athena NLQ)
ANTHROPIC_API_KEY=""
